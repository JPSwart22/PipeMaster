+            double[] a = trackPath.get(i), b = trackPath.get(i + 1);
+            double segM = haversineMeters(a, b);
+            double mPerDegLat = 111320;
+            double mPerDegLon = 111320 * Math.cos(Math.toRadians(a[0]));
+            double bx = (b[1] - a[1]) * mPerDegLon, by = (b[0] - a[0]) * mPerDegLat;
